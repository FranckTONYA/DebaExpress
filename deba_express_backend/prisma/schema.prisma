// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum TypeMesure {
  POIDS  // Calcul : poids * prixUnitaire
  PIECE  // Calcul : nombrePiece * prixUnitaire
}

enum StatutEnvoi {
  ENREGISTRE
  EN_ENTREPOT
  EN_VOL
  DOUANE
  ARRIVE_DESTINATION
  LIVRE
}

model CategorieColis {
  id             String               @id @default(uuid())
  nom            String               @unique // Ex: "Électronique", "Vêtements"
  description    String?
  
  // Valeurs génériques obligatoires au niveau de la catégorie
  prixUnitaire   Float
  mesure         TypeMesure 
  
  sousCategories SousCategorieColis[]
  createdAt      DateTime             @default(now())
}

model SousCategorieColis {
  id           String         @id @default(uuid())
  nom          String         // Ex: "Téléphone", "Ordinateur", "Robe"
  
  // OPTIONNELS (?) : Si présents, ils écrasent les valeurs de la catégorie.
  // Si null, l'API lira automatiquement les valeurs de la catégorie parente.
  prixUnitaire Float?         
  mesure       TypeMesure?    
  
  categorieId  String
  categorie    CategorieColis @relation(fields: [categorieId], references: [id], onDelete: Cascade)
  
  colis        Colis[]        
  createdAt    DateTime       @default(now())

  @@unique([nom, categorieId]) 
}

model Client {
  id              String   @id @default(uuid())
  numeroClient    String   @unique
  nom             String
  prenom          String
  email           String   @unique
  telephone       String
  adresse         String
  colis           Colis[]  @relation("ClientExpediteur")
  createdAt       DateTime @default(now())
}

model Colis {
  id              String             @id @default(uuid())
  codeSuivi       String?            @unique
  description     String?
  
  // Historisation des valeurs appliquées au moment du dépôt
  prixUnitaireApp Float              
  mesureApp       TypeMesure         
  
  poids           Float?             
  nombrePiece     Int?               
  prixTotal       Float
  dateDepot       DateTime
  dateEnvoi       DateTime
  dateReception   DateTime             
  etatSortie      String?
  statut          StatutEnvoi        @default(ENREGISTRE)
  
  sousCategorieId String
  sousCategorie   SousCategorieColis @relation(fields: [sousCategorieId], references: [id])
  
  expediteurId    String
  expediteur      Client             @relation("ClientExpediteur", fields: [expediteurId], references: [id], onDelete: Cascade)
  
  facture         Facture?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Facture {
  id          String   @id @default(uuid())
  numeroFact  String   @unique
  montant     Float
  avance      Float
  estPaye     Boolean  @default(false)
  
  colisId     String   @unique
  colis       Colis    @relation(fields: [colisId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}
