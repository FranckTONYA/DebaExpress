{
  "name": "deba-express-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npx tailwindcss -i ./src/styles.css -o ./src/assets/tailwind.css --watch & ng serve",
    "build": "npx tailwindcss -i ./src/styles.css -o ./src/assets/tailwind.css --minify && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:deba_express_frontend": "node dist/deba_express_frontend/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.1",
    "@tailwindcss/cli": "^4.3.1",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "autoprefixer": "^10.5.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
